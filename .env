# Create a .env file (copy from .env.example)
cp .env.example .env
// ❌ Wrong - This won't work in Vite
const API_KEY = process.env.GEMINI_API_KEY;

// ✅ Correct - Vite uses import.meta.env
const API_KEY = import.meta.env.VITE_GEMINI_API_KEY;

// Or if you want to keep the name as GEMINI_API_KEY:
const API_KEY = import.meta.env.GEMINI_API_KEY;
# .env (not .env.example)
VITE_GEMINI_API_KEY="sk-or-v1-5b2561bad30d785b2b276882116b84322181f12c92dd09690f0bb9263f954d5"
// Where you initialize the client
const OPENROUTER_API_KEY = import.meta.env.VITE_GEMINI_API_KEY;

if (!OPENROUTER_API_KEY) {
  console.error('API key is missing! Check your .env file');
  // Show user-friendly error
}

const sTe = new aTe({
  apiKey: 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,  // Now this will have the actual key
  vertexai: false,
  httpOptions: {
    baseUrl: "https://openrouter.ai/api/v1"
  }
});
